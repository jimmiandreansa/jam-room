# Supabase (public — safe for the browser / Vercel)
# URL = project root only: https://YOUR_REF.supabase.co — do NOT add /rest/v1
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# YouTube Data API v3 (server-only — never NEXT_PUBLIC_)
# Powers in-room song search.
YOUTUBE_API_KEY=YOUR_SERVER_KEY

# Cloudflare R2 (server-only — never NEXT_PUBLIC_)
# Used by the standalone "My Library" upload feature (Google sign-in).
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=jam-songs
# Optional: public custom domain for covers, e.g. https://media.example.com
# R2_PUBLIC_URL=https://YOUR_R2_PUBLIC_DOMAIN
